# AgentLens Environment Configuration
# Copy this file to .env and fill in your values

# ─── Platform ────────────────────────────────────────────────────
AGENTLENS_ENV=development               # development | staging | production
AGENTLENS_SECRET_KEY=change-me-in-prod  # JWT signing secret
AGENTLENS_API_HOST=0.0.0.0
AGENTLENS_API_PORT=8000
AGENTLENS_CORS_ORIGINS=http://localhost:3000

# ─── Database: ClickHouse (Trace Storage) ────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=agentlens
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ─── Cache / Sessions: Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Message Bus: Kafka ──────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_TRACES=agentlens.traces
KAFKA_TOPIC_METRICS=agentlens.metrics
KAFKA_TOPIC_ALERTS=agentlens.alerts

# ─── Metrics: Prometheus ─────────────────────────────────────────
PROMETHEUS_PORT=9090

# ─── Evaluation Engine ───────────────────────────────────────────
EVALUATION_MODEL=gpt-4o                 # judge model
OPENAI_API_KEY=
ANTHROPIC_API_KEY=                      # optional second judge

# ─── LLM Provider Cost Tracking ──────────────────────────────────
# Comma-separated provider names to enable cost tracking
ENABLED_PROVIDERS=openai,anthropic,google,mistral,bedrock,azure_openai

# ─── Object Storage (Eval Artifacts) ─────────────────────────────
S3_ENDPOINT=http://localhost:9000       # MinIO or AWS S3
S3_BUCKET=agentlens-artifacts
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ─── Alerts / Notifications ──────────────────────────────────────
SLACK_WEBHOOK_URL=
PAGERDUTY_API_KEY=
ALERT_EMAIL_FROM=alerts@agentlens.io
SMTP_HOST=localhost
SMTP_PORT=587

# ─── PII Redaction ───────────────────────────────────────────────
PII_REDACTION_ENABLED=true
PII_REDACTION_PATTERNS=email,phone,ssn,credit_card

# ─── Feature Flags ───────────────────────────────────────────────
FEATURE_EVALUATIONS=true
FEATURE_SHADOW_AGENT_DISCOVERY=false    # P2 feature
FEATURE_AI_COPILOT=false                # P2 feature
